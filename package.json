{
  "name": "joblog-analyzer",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.0.0",
  "license": "MIT",
  "publisher": "remainsoftware",
  "repository": {
    "type": "git",
    "url": "https://github.com/RemainSoftware/jla.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:joblog",
    "workspaceContains:**/QPJOBLOG*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "joblog",
        "aliases": [
          "%language.joblog.name%",
          "joblog"
        ],
        "filenames": [
          "QPJOBLOG"
        ],
        "filenamePatterns": [
          "**/QPJOBLOG*",
          "**/*joblog*"
        ]
      }
    ],
    "commands": [
      {
        "command": "joblogAnalyzer.analyze",
        "title": "%command.analyze.title%",
        "category": "%command.analyze.category%"
      },
      {
        "command": "joblogAnalyzer.setAsJobLog",
        "title": "%command.setAsJobLog.title%",
        "category": "%command.setAsJobLog.category%"
      },
      {
        "command": "joblogAnalyzer.refresh",
        "title": "%command.refresh.title%",
        "category": "%command.refresh.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "joblogAnalyzer.goToMessage",
        "title": "%command.goToMessage.title%",
        "category": "%command.goToMessage.category%"
      },
      {
        "command": "joblogAnalyzer.filterByType",
        "title": "%command.filterByType.title%",
        "category": "%command.filterByType.category%",
        "icon": "$(filter)"
      },
      {
        "command": "joblogAnalyzer.showHighSeverity",
        "title": "%command.showHighSeverity.title%",
        "category": "%command.showHighSeverity.category%",
        "icon": "$(warning)"
      },
      {
        "command": "joblogAnalyzer.filterByMessageId",
        "title": "%command.filterByMessageId.title%",
        "category": "%command.filterByMessageId.category%",
        "icon": "$(search)"
      },
      {
        "command": "joblogAnalyzer.clearFilters",
        "title": "%command.clearFilters.title%",
        "category": "%command.clearFilters.category%",
        "icon": "$(clear-all)"
      },
      {
        "command": "joblogAnalyzer.openFilterMenu",
        "title": "%command.openFilterMenu.title%",
        "category": "%command.openFilterMenu.category%",
        "icon": "$(filter)"
      },
      {
        "command": "joblogAnalyzer.toggleCommandMessages",
        "title": "%command.toggleCommandMessages.title%",
        "category": "%command.toggleCommandMessages.category%",
        "icon": "$(terminal)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "joblogAnalyzer",
          "title": "%viewContainer.title%",
          "icon": "$(list-tree)"
        }
      ]
    },
    "views": {
      "joblogAnalyzer": [
        {
          "id": "joblogAnalyzer",
          "name": "%view.joblogAnalyzer.name%",
          "when": "joblogAnalyzer.isJobLog",
          "icon": "$(list-tree)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "joblogAnalyzer.refresh",
          "when": "view == joblogAnalyzer",
          "group": "navigation"
        },
        {
          "command": "joblogAnalyzer.openFilterMenu",
          "when": "view == joblogAnalyzer",
          "group": "navigation"
        },
        {
          "command": "joblogAnalyzer.clearFilters",
          "when": "view == joblogAnalyzer",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "joblogAnalyzer.setAsJobLog",
          "group": "joblog"
        }
      ],
      "commandPalette": [
        {
          "command": "joblogAnalyzer.goToMessage",
          "when": "joblogAnalyzer.isJobLog"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "joblogAnalyzer.highSeverityThreshold": {
          "type": "number",
          "default": 30,
          "description": "%config.highSeverityThreshold.description%"
        },
        "joblogAnalyzer.hideCommandMessages": {
          "type": "boolean",
          "default": true,
          "description": "%config.hideCommandMessages.description%"
        },
        "joblogAnalyzer.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoDetect.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
