{
  "name": "joblog-detective",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.1.1",
  "license": "MIT",
  "publisher": "remainsoftware",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/RemainSoftware/jld.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:joblog",
    "workspaceContains:**/QPJOBLOG*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "joblog",
        "aliases": [
          "%language.joblog.name%",
          "joblog"
        ],
        "filenames": [
          "QPJOBLOG"
        ],
        "filenamePatterns": [
          "**/QPJOBLOG*",
          "**/*joblog*.txt",
          "**/*joblog*.txt",
          "**/*.joblog"
        ]
      }
    ],
    "commands": [
      {
        "command": "joblogDetective.analyze",
        "title": "%command.analyze.title%",
        "category": "%command.analyze.category%"
      },
      {
        "command": "joblogDetective.setAsJobLog",
        "title": "%command.setAsJobLog.title%",
        "category": "%command.setAsJobLog.category%"
      },
      {
        "command": "joblogDetective.refresh",
        "title": "%command.refresh.title%",
        "category": "%command.refresh.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "joblogDetective.goToMessage",
        "title": "%command.goToMessage.title%",
        "category": "%command.goToMessage.category%"
      },
      {
        "command": "joblogDetective.filterByType",
        "title": "%command.filterByType.title%",
        "category": "%command.filterByType.category%",
        "icon": "$(filter)"
      },
      {
        "command": "joblogDetective.showHighSeverity",
        "title": "%command.showHighSeverity.title%",
        "category": "%command.showHighSeverity.category%",
        "icon": "$(warning)"
      },
      {
        "command": "joblogDetective.filterByMessageId",
        "title": "%command.filterByMessageId.title%",
        "category": "%command.filterByMessageId.category%",
        "icon": "$(search)"
      },
      {
        "command": "joblogDetective.filterByContent",
        "title": "%command.filterByContent.title%",
        "category": "%command.filterByContent.category%",
        "icon": "$(note)"
      },
      {
        "command": "joblogDetective.clearFilters",
        "title": "%command.clearFilters.title%",
        "category": "%command.clearFilters.category%",
        "icon": "$(clear-all)"
      },
      {
        "command": "joblogDetective.openFilterMenu",
        "title": "%command.openFilterMenu.title%",
        "category": "%command.openFilterMenu.category%",
        "icon": "$(filter)"
      },
      {
        "command": "joblogDetective.toggleCommandMessages",
        "title": "%command.toggleCommandMessages.title%",
        "category": "%command.toggleCommandMessages.category%",
        "icon": "$(terminal)"
      },
      {
        "command": "joblogDetective.toggleDecorations",
        "title": "%command.toggleDecorations.title%",
        "category": "%command.toggleDecorations.category%",
        "icon": "$(paintcan)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "joblogDetective",
          "title": "%viewContainer.title%",
          "icon": "$(list-tree)"
        }
      ]
    },
    "views": {
      "joblogDetective": [
        {
          "id": "joblogDetective",
          "name": "%view.joblogDetective.name%",
          "when": "joblogDetective.isJobLog",
          "icon": "$(list-tree)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "joblogDetective.refresh",
          "when": "view == joblogDetective",
          "group": "navigation"
        },
        {
          "command": "joblogDetective.openFilterMenu",
          "when": "view == joblogDetective",
          "group": "navigation"
        },
        {
          "command": "joblogDetective.clearFilters",
          "when": "view == joblogDetective",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "joblogDetective.setAsJobLog",
          "group": "joblog"
        }
      ],
      "commandPalette": [
        {
          "command": "joblogDetective.goToMessage",
          "when": "joblogDetective.isJobLog"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "joblogDetective.highSeverityThreshold": {
          "type": "number",
          "default": 30,
          "description": "%config.highSeverityThreshold.description%"
        },
        "joblogDetective.hideCommandMessages": {
          "type": "boolean",
          "default": true,
          "description": "%config.hideCommandMessages.description%"
        },
        "joblogDetective.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoDetect.description%"
        },
        "joblogDetective.enableEditorDecorations": {
          "type": "boolean",
          "default": true,
          "description": "%config.enableEditorDecorations.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^10.0.2",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
